<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleExecutable</key>
    <string>${MACOSX_BUNDLE_EXECUTABLE_NAME}</string>
    <key>CFBundleIdentifier</key>
    <string>app.tenjin.Tenjin</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>Tenjin</string>
    <key>CFBundleDisplayName</key>
    <string>Tenjin</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>${MACOSX_BUNDLE_SHORT_VERSION_STRING}</string>
    <key>CFBundleVersion</key>
    <string>${MACOSX_BUNDLE_BUNDLE_VERSION}</string>

    <!-- App icon. The asset catalog (Assets.xcassets/AppIcon.appiconset) is
         compiled by Xcode and produces the actual icon files; this key names
         the set. Without it iOS shows a blank home-screen icon and some
         sideload validators warn. -->
    <key>CFBundleIconName</key>
    <string>AppIcon</string>
    <key>CFBundleIcons</key>
    <dict>
        <key>CFBundlePrimaryIcon</key>
        <dict>
            <key>CFBundleIconName</key>
            <string>AppIcon</string>
        </dict>
    </dict>

    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>MinimumOSVersion</key>
    <string>16.0</string>
    <key>CFBundleSupportedPlatforms</key>
    <array>
        <string>iPhoneOS</string>
    </array>
    <key>UIDeviceFamily</key>
    <array>
        <integer>1</integer>
        <integer>2</integer>
    </array>
    <key>UILaunchScreen</key>
    <dict/>

    <!-- Cross-device sync: Tenjin exports/imports its whole collection as JSON.
         These two keys make the app's Documents directory visible in the Files
         app and in Finder/iTunes file sharing, so the user can actually move
         the export file on/off the device — essential on iOS, which otherwise
         sandboxes Documents away from the user. -->
    <key>UIFileSharingEnabled</key>
    <true/>
    <key>LSSupportsOpeningDocumentsInPlace</key>
    <true/>

    <!-- Let Tenjin be offered as an "Open in" target for .json export files. -->
    <key>CFBundleDocumentTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeName</key>
            <string>Tenjin Collection</string>
            <key>LSHandlerRank</key>
            <string>Default</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>public.json</string>
            </array>
        </dict>
    </array>

    <!-- QtMultimedia / media access usage strings. iOS terminates the app if a
         protected-resource API is touched without these present. Playback of
         bundled/local media doesn't always need them, but having them avoids
         hard crashes if a media path probes the photo library, mic, or camera. -->
    <key>NSPhotoLibraryUsageDescription</key>
    <string>Tenjin can attach images and videos to your word cards.</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>Tenjin can record audio for pronunciation notes.</string>
    <key>NSAppleMusicUsageDescription</key>
    <string>Tenjin can play audio attached to your cards.</string>

    <!-- Declares the app uses no non-exempt encryption, so neither AltStore nor
         App Store Connect prompts an export-compliance question on each upload. -->
    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>

    <key>UIRequiredDeviceCapabilities</key>
    <array>
        <string>arm64</string>
    </array>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
</dict>
</plist>

