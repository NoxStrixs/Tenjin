#!/usr/bin/env python3
"""
Tenjin development tool.

Single entry point for every build, test, analyze, and package operation.
Each subcommand lives in a module under scripts/ that exports `register()`
and a callable; the dispatcher just wires them in.
"""

import argparse
import logging
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))

from scripts import (
    analyze,
    benchmark,
    build,
    clean,
    docker_build,
    docker_shell,
    format,
    package,
    test,
)

logger = logging.getLogger(__name__)


def register_commands(subparsers):
    commands = [
        build,
        test,
        analyze,
        benchmark,
        format,
        package,
        clean,
        docker_build,
        docker_shell,
    ]
    for command in commands:
        command.register(subparsers)


def main():
    logging.basicConfig(
        level  = logging.INFO,
        format = "%(message)s",
    )

    parser = argparse.ArgumentParser(
        prog        = "tool",
        description = "Tooling script for Tenjin development.",
        epilog      = "Run 'tool <command> --help' for command-specific options.",
    )

    subparsers = parser.add_subparsers(dest="command", required=True)
    register_commands(subparsers)

    args = parser.parse_args()
    args.func(args)

    logger.info("Done")


if __name__ == "__main__":
    main()
