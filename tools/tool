#!/usr/bin/env python3

import argparse
import logging
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))

from scripts import (
    build,
    clean,
    docker_build,
    docker_shell,
    format,
    package,
    translation,
)

logger = logging.getLogger(__name__)


def register_commands(subparsers):
    commands = [
        build,
        format,
        package,
        clean,
        docker_build,
        docker_shell,
        translation,
    ]
    for command in commands:
        command.register(subparsers)


def main():
    logging.basicConfig(
        level  = logging.INFO,
        format = "%(message)s",
    )

    parser = argparse.ArgumentParser(
        prog        = "tool",
        description = "Tooling script for Tenjin development.",
        epilog      = "Run 'tool <command> --help' for command-specific options.",
    )

    subparsers = parser.add_subparsers(dest="command", required=True)
    register_commands(subparsers)

    args = parser.parse_args()
    args.func(args)

    logger.info("Done")


if __name__ == "__main__":
    main()
