#!/bin/sh
# Thin wrapper for cross-compile cmake invocations. Mirrors what qt-cmake from
# the mingw_64 SDK would do, but reliable from Linux (aqtinstall's mingw_64
# qt-cmake is not — miurahr/aqtinstall#793).
set -eu

: "${QT_VERSION:=6.8.3}"
: "${QT_HOST_PATH:=/opt/Qt/${QT_VERSION}/gcc_64}"
: "${QT_TARGET_PATH:=/opt/Qt/${QT_VERSION}/mingw_64}"

exec cmake \
    -G Ninja \
    -DCMAKE_TOOLCHAIN_FILE="${QT_TARGET_PATH}/lib/cmake/Qt6/qt.toolchain.cmake" \
    -DQT_HOST_PATH="${QT_HOST_PATH}" \
    -DQT_HOST_PATH_CMAKE_DIR="${QT_HOST_PATH}/lib/cmake" \
    -DCMAKE_C_COMPILER=x86_64-w64-mingw32-gcc-posix \
    -DCMAKE_CXX_COMPILER=x86_64-w64-mingw32-g++-posix \
    -DCMAKE_RC_COMPILER=x86_64-w64-mingw32-windres \
    -DCMAKE_FIND_ROOT_PATH_MODE_PROGRAM=NEVER \
    -DCMAKE_FIND_ROOT_PATH_MODE_LIBRARY=ONLY \
    -DCMAKE_FIND_ROOT_PATH_MODE_INCLUDE=ONLY \
    -DCMAKE_FIND_ROOT_PATH_MODE_PACKAGE=ONLY \
    "$@"
